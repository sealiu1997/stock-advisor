<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.stockadvisor.market-watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>-m</string>
        <string>market_watcher</string>
        <string>run</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/liuhaiyang/code/Stock_Analysis/stock-advisor</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/Users/liuhaiyang/code/Stock_Analysis/stock-advisor/scripts</string>
